# انسخ إلى `.env.testing` لاستخدام قاعدة اختبار منفصلة (أسرع من مشاركة قاعدة التطوير مع RefreshDatabase).
# أثناء `php artisan test` يحمّل Laravel هذا الملف تلقائياً إن وُجد.

APP_ENV=testing
APP_KEY=base64:PLACEHOLDER_USE_php_artisan_key_generate

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=magzani_testing
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
