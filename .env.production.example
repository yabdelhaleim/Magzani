BROADCAST_DRIVER=log
CACHE_DRIVER=file  # يمكن استخدام redis للأداء الأفضل
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync  # يمكن استخدام database للإنتاج
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
