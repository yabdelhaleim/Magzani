APP_NAME=Laravel
APP_ENV=production
APP_KEY=base64:E94GRNOM8vEz1AI6MDCMQehdY9weJLi+diwWPGGQ8go=
APP_DEBUG=false  # ⚠️ مهم: يجب أن يكون false في الإنتاج
APP_URL=https://superdashboard.remotelly1.site

# Comma-separated central (landlord) domains — NOT tenant domains.
# bakedgekayan.remotelly1.site is the public-facing pricing page subdomain.
# Adjust this list if your pricing subdomain is different.
CENTRAL_DOMAINS=superdashboard.remotelly1.site,bakedgekayan.remotelly1.site
TENANT_DOMAIN_SUFFIX=remotelly1.site
TENANT_URL_SCHEME=https
# Leave empty on production (default HTTPS port)
TENANT_URL_PORT=

# --- Public Pricing Page (Kayyan SaaS marketing site) ---
# "احجز ديمو" buttons → the main Remotelly website
# "ابدأ تجربتك" buttons → the Kayan platform login (trial)
KAYYAN_DEMO_URL=https://remotelly1.site/
KAYYAN_SIGNUP_URL=https://kayan.remotelly1.site/login
KAYYAN_BRAND_NAME="كيان SaaS"
KAYYAN_BRAND_TAGLINE="نظام إدارة الأعمال والمخازن الذكي"
KAYYAN_SEO_TITLE="الأسعار | كيان SaaS - نظام إدارة الأعمال الذكي"
KAYYAN_SEO_DESCRIPTION="اختر باقة كيان SaaS المناسبة لنمو أعمالك. باقات مرنة تبدأ من 99 ريال شهرياً تشمل نقاط البيع، التصنيع، المحاسبة المتقدمة، والتقارير المالية."
KAYYAN_SEO_KEYWORDS="نظام إدارة أعمال, نقاط بيع, محاسبة, تصنيع, مخازن, فواتير, كيان SaaS, Magzani, ERP, POS"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning  # ⚠️ مهم: warning أو error بدلاً من debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=magzany
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file  # يمكن استخدام redis للأداء الأفضل
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync  # يمكن استخدام database للإنتاج
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=4443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# إعدادات الأمان الإضافية
SESSION_SECURE_COOKIE=true
SANCTUM_STATIC=true
TRUSTED_PROXIES="*"
